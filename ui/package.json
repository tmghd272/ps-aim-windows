{
  "name": "ps-aim-ui",
  "version": "1.0.0",
  "description": "PSVR Aim Driver Emulator",
  "author": "TMGHD272",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^28.0.0",
